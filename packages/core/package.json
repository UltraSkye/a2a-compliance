{
  "name": "@a2a-compliance/core",
  "version": "0.0.0",
  "description": "Assertion engine and reporters (JSON, JUnit, badge SVG) for A2A protocol compliance testing",
  "keywords": [
    "a2a",
    "agent2agent",
    "compliance",
    "testing",
    "tck",
    "llm",
    "protocol"
  ],
  "license": "MIT",
  "homepage": "https://github.com/UltraSkye/a2a-compliance#readme",
  "bugs": "https://github.com/UltraSkye/a2a-compliance/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/UltraSkye/a2a-compliance.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@a2a-compliance/schemas": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
