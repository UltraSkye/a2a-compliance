{
  "name": "@a2a-compliance/cli",
  "version": "0.0.0",
  "description": "CLI for running A2A protocol compliance tests against agent endpoints",
  "keywords": [
    "a2a",
    "agent2agent",
    "compliance",
    "cli",
    "testing",
    "protocol"
  ],
  "license": "MIT",
  "homepage": "https://github.com/UltraSkye/a2a-compliance#readme",
  "bugs": "https://github.com/UltraSkye/a2a-compliance/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/UltraSkye/a2a-compliance.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "a2a-compliance": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@a2a-compliance/core": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
