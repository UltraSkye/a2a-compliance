{
  "name": "@a2a-compliance/schemas",
  "version": "0.3.3",
  "description": "Zod schemas for the A2A (Agent2Agent) protocol: Agent Card, JSON-RPC 2.0 envelope, Task, Message, Part. Zero runtime deps beyond Zod; runs in Node / Bun / Deno / browser / edge.",
  "keywords": [
    "a2a",
    "a2a-protocol",
    "a2a-schema",
    "a2a-compliance",
    "a2a-validator",
    "agent2agent",
    "agent-card",
    "agent-card-schema",
    "agent-card-validator",
    "agent-protocol",
    "ai-agent",
    "ai-agents",
    "llm-agent",
    "llm-tools",
    "google-a2a",
    "zod",
    "zod-schema",
    "schema",
    "validator",
    "json-schema",
    "jsonrpc",
    "json-rpc",
    "json-rpc-2.0",
    "protocol",
    "typescript",
    "types",
    "message",
    "task"
  ],
  "license": "MIT",
  "author": "a2a-compliance contributors",
  "homepage": "https://github.com/UltraSkye/a2a-compliance#readme",
  "bugs": "https://github.com/UltraSkye/a2a-compliance/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/UltraSkye/a2a-compliance.git",
    "directory": "packages/schemas"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
