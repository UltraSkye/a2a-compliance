{
  "name": "a2a-compliance",
  "version": "0.3.3",
  "private": true,
  "description": "Compliance test kit and validator for A2A (Agent2Agent) protocol endpoints",
  "license": "MIT",
  "author": "",
  "type": "module",
  "engines": {
    "node": ">=22.10.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "dev": "pnpm -r --parallel --filter=./packages/* dev",
    "test": "pnpm -r --filter=./packages/* test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r --filter=./packages/* typecheck",
    "cli": "pnpm --filter @a2a-compliance/cli start",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
    "prepare": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
